---
import { Nav } from '@/components/react/Nav'
import { getPayload } from 'payload'
import { config, getStaticUrl, MediaSubDir, getCertainSizeImageName, type BannerImage } from 'payload-app'

import { BannerPages } from 'payload-app/consts'
import { NavProvider } from '@/components/context/NavContext'
import { BannerImages } from '@/lib/image'
import { getImage } from 'astro:assets'
import logo from '@/assets/logo.svg'

const logoIcon = await getImage({ src: logo, format: 'svg' })
const payload = await getPayload({ config })

const categories = await payload.find({ collection: 'product-categories', pagination: false })
const industries = await payload.find({ collection: 'industries', pagination: false })
const stars = await payload.find({ collection: 'star-products', pagination: false })
const banners = await payload.findGlobal({ slug: 'banners'})

const productCategories = categories.docs.slice(0, 6).map((item) => ({
  id: item.id,
  name: item.name ?? ''
}))
const topIndustries = industries.docs.map((item) => ({
  id: item.id,
  name: item.name ?? '',
  cover: typeof item.thumbnail === 'object' ? getStaticUrl(MediaSubDir.IndustryImages, getCertainSizeImageName(item.thumbnail, 'normal')) : ''
}))
const starProducts = stars.docs.map((item) => ({
  id: item.id,
  name: item.name ?? '',
  productId: typeof item.product === 'object' ? item.product.id : '',
  cover: typeof item.cover === 'object' ? getStaticUrl(MediaSubDir.StarProductImages, getCertainSizeImageName(item.cover, 'normal')) : ''
}))

const bannerImages = await Promise.all(Object.entries(BannerImages).map(([pageType, meta]) => getImage({
  src: meta,
  format: 'jpeg',
}).then(res => ({
  pageType,
  meta: res
}))))

const normalizeBanners = Object.fromEntries(BannerPages.map((pageType) => {

  const backupBanner = bannerImages.find((item) => item.pageType === pageType)
  // @ts-ignore
  const foundBanner = banners[pageType] as BannerImage
  if (!foundBanner || !foundBanner.filename) return [
    pageType,
    {
      normal: backupBanner?.meta.src,
      cropped: backupBanner?.meta.src
    }
  ]
  const normal = getStaticUrl(MediaSubDir.BannerImages, foundBanner.filename ?? '')
  const cropped = getStaticUrl(MediaSubDir.BannerImages, getCertainSizeImageName(foundBanner, 'cropped'))
  return [
    pageType,
    { normal, cropped }
  ]
}))

const routePattern = Astro.routePattern
---
<NavProvider client:load {...{
  productCategories,
  industries: topIndustries,
  starProducts,
  bannerMap: normalizeBanners
}}>{}</NavProvider>
<Nav client:load routePattern={routePattern} logoSrc={logoIcon.src} />
